{
  "compilerOptions": {
    "target": "es2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "types": ["node"],
    "ignoreDeprecations": "6.0",
    "baseUrl": "." 
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules"
  ]
}